{
  "manifest_version": 3,
  "name": "evyAI Assistant",
  "version": "1.0.0",
  "description": "AI-powered LinkedIn comments & messages",
  "permissions": ["sidePanel", "activeTab", "storage", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "evyAI Assistant"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*"],
    "js": ["content.js"]
  }]
}